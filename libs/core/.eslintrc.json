{
  "extends": [
    "../../.eslintrc.json"
  ],
  "ignorePatterns": [
    "!**/*",
    "src/lib/search/oql/OQLLexer.ts",
    "src/lib/search/oql/OQLParser.ts",
    "src/lib/search/oql/OQLListener.ts",
    "src/lib/search/oql/OQLParseListener.ts"
  ],
  "overrides": [
    {
      "files": [
        "*.ts"
      ],
      "rules": {
        "@angular-eslint/directive-selector": [
          "error",
          {
            "type": "attribute",
            "prefix": "renwu",
            "style": "camelCase"
          }
        ],
        "@angular-eslint/component-selector": [
          "error",
          {
            "type": "element",
            "prefix": "renwu",
            "style": "kebab-case"
          }
        ],
        "@angular-eslint/prefer-standalone": "error",
        "@angular-eslint/prefer-inject": "warn"
      },
      "extends": [
        "plugin:@nx/angular",
        "plugin:@angular-eslint/template/process-inline-templates"
      ]
    },
    {
      "files": [
        "**/bootstrap.ts",
        "**/app.module.ts"
      ],
      "rules": {
        "@nx/enforce-module-boundaries": "off"
      }
    },
    {
      "files": [
        "*.html"
      ],
      "extends": [
        "plugin:@nx/angular-template"
      ],
      "rules": {
        "@angular-eslint/template/prefer-self-closing-tags": "error"
      }
    },
    {
      "files": [
        "src/lib/markdown/markdown.service.ts"
      ],
      "rules": {
        "no-useless-escape": "off",
        "no-empty": "off"
      }
    },
    {
      "files": [
        "src/lib/select/dictionary-id.ts",
        "src/lib/select/format.service.ts"
      ],
      "rules": {
        "@typescript-eslint/no-empty-object-type": "off",
        "@typescript-eslint/no-unsafe-function-type": "off"
      }
    }
  ]
}
